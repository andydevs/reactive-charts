{
    "name": "reactive-charts-workspace",
    "version": "1.0.0",
    "private": true,
    "author": "Andydevs <akanshul97@gmail.com>",
    "license": "MIT",
    "workspaces": [
        "workspaces/*"
    ],
    "scripts": {
        "build:lib": "yarn workspace reactive-charts build",
        "build:lib:watch": "yarn workspace reactive-charts build:watch",
        "build:site:webpack": "yarn workspace demo-site build",
        "serve:site:webpack": "yarn workspace demo-site start",
        "build": "concurrently \"yarn build:lib\" \"yarn build:site:webpack\"",
        "start": "concurrently \"yarn build:lib:watch\" \"yarn serve:site:webpack\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
